    "name": "1. Flow Pemasok",
    "commands": [{
      "id": "9a5a6700-8e9b-495e-9788-5f62470ae8e2",
      "comment": "1. Membuka halaman login",
      "command": "open",
      "target": "/home/index.php",
      "targets": [],
      "value": ""
    }, {
      "id": "window-size-id-sup",
      "comment": "2. Mengatur ukuran jendela browser",
      "command": "setWindowSize",
      "target": "1280x800",
      "targets": [],
      "value": ""
    }, {
      "id": "wait-user-sup",
      "comment": "3. Menunggu kolom username",
      "command": "waitForElementPresent",
      "target": "name=username",
      "targets": [
        ["name=username", "name"]
      ],
      "value": "30000"
    }, {
      "id": "pause-1-sup",
      "comment": "4. Jeda sejenak sebelum input",
      "command": "pause",
      "target": "1000",
      "targets": [],
      "value": ""
    }, {
      "id": "exec-user-sup",
      "comment": "5. Input Username (via Script)",
      "command": "executeScript",
      "target": "document.getElementsByName('username')[0].value='admin'",
      "targets": [],
      "value": ""
    }, {
      "id": "exec-pass-sup",
      "comment": "6. Input Password (via Script)",
      "command": "executeScript",
      "target": "document.getElementsByName('password')[0].value='1234'",
      "targets": [],
      "value": ""
    }, {
      "id": "click-login-sup",
      "comment": "7. Klik tombol Login",
      "command": "click",
      "target": "name=submit",
      "targets": [
        ["name=submit", "name"]
      ],
      "value": ""
    }, {
      "id": "pause-2-sup",
      "comment": "8. Jeda proses login",
      "command": "pause",
      "target": "2000",
      "targets": [],
      "value": ""
    }, {
      "id": "nav-sup",
      "comment": "9. Navigasi langsung ke halaman Pemasok",
