      "target": "xpath=//input[@value='SIMPAN']",
      "targets": [
        ["xpath=//input[@value='SIMPAN']", "xpath:attributes"]
      ],
      "value": ""
    }, {
      "id": "pause-4-sup",
      "comment": "17. Jeda setelah simpan",
      "command": "pause",
      "target": "2000",
      "targets": [],
      "value": ""
    }, {
      "id": "click-edit-sup",
      "comment": "18. Cari 'Pemasok Test' dan klik Edit",
      "command": "click",
      "target": "xpath=//tr[td[contains(.,'Pemasok Test')]]//input[@value='EDIT']",
      "targets": [
        ["xpath=//tr[td[contains(.,'Pemasok Test')]]//input[@value='EDIT']", "xpath:attributes"]
